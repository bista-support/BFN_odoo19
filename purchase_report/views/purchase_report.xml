<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="purchase.report_purchaseorder_document">
        <t t-call="web.external_layout">
            <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>
            
            <!-- Addresses -->
            <t t-set="address">
                <div t-field="o.partner_id"
                     t-options='{"widget": "contact", "fields": ["address","name","phone","vat"], "no_marker": True, "phone_icons": True}'/>
            </t>

            <t t-if="o.dest_address_id">
                <t t-set="information_block">
                    <strong>Shipping address:</strong>
                    <div t-field="o.dest_address_id"
                         t-options='{"widget": "contact", "fields": ["address","name","phone"], "no_marker": True, "phone_icons": True}'
                         name="purchase_shipping_address"/>
                </t>
            </t>

            <div class="page">
                <!-- Title -->
                <div>
                    <h2 t-if="o.state in ['draft','sent','to approve']">Request for Quotation #<span t-field="o.name"/></h2>
                    <h2 t-if="o.state in ['purchase','done']">Purchase Order #<span t-field="o.name"/></h2>
                    <h2 t-if="o.state == 'cancel'">Cancelled Purchase Order #<span t-field="o.name"/></h2>
                </div>

                <!-- Information Blocks -->
                <div style="page-break-inside: avoid;">
                    <div id="informations_new" class="row" style="margin:0;">
                        <div t-if="o.user_id" class="col-3">
                            <strong>Vendor:</strong>
                            <p t-field="o.user_id" style="margin:0"/>
                        </div>
                        <div class="col-3">
                            <strong>Date Created:</strong>
                            <p t-field="o.date_order" style="margin:0"/>
                        </div>
                        <div t-if="o.state in ['purchase','done'] and o.date_approve" class="col-3">
                            <strong>Payment Terms:</strong>
                            <p t-field="o.payment_term_id" style="margin:0"/>
                        </div>



                        <div class="col-3">
                            <strong>Ship To:</strong>
                            <p style="margin:0">
                                <t t-esc="o.picking_type_id.warehouse_id.partner_id.name"/>
                            </p>
                            <p style="margin:0">
                                <t t-esc="o.picking_type_id.warehouse_id.partner_id.street or ''"/>
                                <t t-if="o.picking_type_id.warehouse_id.partner_id.street2">, <t t-esc="o.picking_type_id.warehouse_id.partner_id.street2"/></t>
                            </p>
                            <p style="margin:0">
                                <t t-esc="o.picking_type_id.warehouse_id.partner_id.city or ''"/>
                                <t t-if="o.picking_type_id.warehouse_id.partner_id.state_id">, <t t-esc="o.picking_type_id.warehouse_id.partner_id.state_id.name"/></t>
                                <t t-if="o.picking_type_id.warehouse_id.partner_id.zip"> - <t t-esc="o.picking_type_id.warehouse_id.partner_id.zip"/></t>
                            </p>
                            <p style="margin:0">
                                <t t-if="o.picking_type_id.warehouse_id.partner_id.country_id" t-esc="o.picking_type_id.warehouse_id.partner_id.country_id.name"/>
                            </p>
                        </div>





                    </div>

                    <div id="informations" class="row" style="margin:0;">
                        <div t-if="o.user_id" class="col-3">
                            <strong>Purchase Representative:</strong>
                            <p t-field="o.user_id" style="margin:0"/>
                        </div>
                        <div t-if="o.partner_ref" class="col-3">
                            <strong>Your Order Reference:</strong>
                            <p t-field="o.partner_ref" style="margin:0"/>
                        </div>
                        <div t-if="o.state in ['purchase','done'] and o.date_approve" class="col-3">
                            <strong>Date Approved:</strong>
                            <p t-field="o.create_date" style="margin:0"/>
                        </div>
                        <div t-elif="o.date_order" class="col-3">
                            <strong>Order Deadline:</strong>
                            <p t-field="o.date_order" style="margin:0"/>
                        </div>
                        <!-- This div is required for purchase_stock module inheritance -->
                        <div t-if="o.date_planned" class="col-2 bm-2">
                            <strong>Expected Arrival:</strong>
                            <p t-field="o.date_planned" t-options="{'date_only': 'true'}" class="m-0"/>
                        </div>
                    </div>

                    <div id="info_contact" class="row" style="margin:0; page-break-inside: avoid;">
                        <div  class="col-3">
                            <strong>Phone:</strong>
                            <p t-field="o.user_id.phone" style="margin:0"/>
                        </div>
                        <div  class="col-3">
                            <strong>Email:</strong>
                            <p t-field="o.user_id.email" style="margin:0"/>
                        </div>
                    </div>
                </div>

                <!-- Order Lines Table -->
                <div style="page-break-inside: avoid;">
                    <table class="table table-sm table-borderless mt-2">
                        <thead>
                            <tr>
                                <th><strong>Description</strong></th>
                                <!-- <th><strong>Taxes</strong></th> -->
                                <!-- <th class="text-center"><strong>Date Req.</strong></th> -->
                                <th class="text-end"><strong>Qty</strong></th>
                                <th class="text-end"><strong>Unit Price</strong></th>
                                <th class="text-end"><strong>Amount</strong></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="o.order_line" t-as="line">
                                <tr t-att-class="'bg-200 fw-bold o_line_section' if line.display_type=='line_section' else 'fst-italic o_line_note' if line.display_type=='line_note' else ''">
                                    <t t-if="not line.display_type">
                                        <td><span t-field="line.name"/></td>
                                        <!-- <t t-set="taxes" t-value="', '.join([(tax.description or tax.name) for tax in line.taxes_id])"/>
                                        <td class="text-end"><span t-out="taxes"/></td> -->
                                        <!-- <td class="text-center"><span t-field="line.date_planned"/></td> -->
                                        <td class="text-end">
                                            <span t-field="line.product_qty"/> <span t-field="line.product_uom_id.name"/>
                                        </td>
                                        <td class="text-end"><span t-field="line.price_unit"/></td>
                                        <td class="text-end">
                                            <span t-field="line.price_subtotal"
                                                t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                                        </td>
                                    </t>
                                    <t t-if="line.display_type == 'line_section'">
                                        <td colspan="99"><span t-field="line.name"/></td>
                                    </t>
                                    <t t-if="line.display_type == 'line_note'">
                                        <td colspan="99"><span t-field="line.name"/></td>
                                    </t>
                                </tr>
                                <t t-if="current_section and (line_last or o.order_line[line_index+1].display_type == 'line_section')">
                                    <tr class="is-subtotal text-end">
                                        <td colspan="99" id="subtotal">
                                            <strong class="mr16">Subtotal</strong>
                                            <span
                                                t-esc="current_subtotal"
                                                t-options='{"widget": "monetary", "display_currency": o.currency_id}'
                                            />
                                        </td>
                                    </tr>
                                </t>
                            </t>
                        </tbody>
                    </table>
                </div>

                <!-- Tax & Total -->
                <div class="row justify-content-end" style="page-break-inside: avoid;">
                    <div class="col-4">
                        <table class="table table-sm table-borderless">
                            <tr>
                                <td><strong>Subtotal</strong></td>
                                <td class="text-end">
                                    <span t-esc="o.amount_untaxed" 
                                          t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                                </td>
                            </tr>
                            <tr>
                                <td><strong>Taxes</strong></td>
                                <td class="text-end">
                                    <span t-esc="o.amount_tax" 
                                          t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                                </td>
                            </tr>
                            <tr>
                                <td><strong>Total</strong></td>
                                <td class="text-end">
                                    <span t-field="o.amount_total" 
                                          t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
                <p t-field="o.note" class="mt-4"/>
                <div class="oe_structure"/>

            </div>
            <!-- <div class="footer" style="text-align:center; font-size:20px; color:gray; margin-top:10px;">
                <t t-esc="o.company_id.name"/>: PO#<t t-esc="o.name"/> : <t t-esc="o.date_order.strftime('%d-%m-%Y')"/>
            </div> -->
            <div class="footer" style="text-align:center; font-size:20px; color:gray; margin-top:10px; border-top: 2px solid black; border-bottom: 2px solid black; padding:5px 0;">
                <t t-esc="o.company_id.name"/>: PO#<t t-esc="o.name"/> : <t t-esc="o.date_order.strftime('%d-%m-%Y')"/>
            </div>

        </t>
    </template>

    <template id="report_purchaseorder">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="purchase.report_purchaseorder_document" t-lang="o.partner_id.lang"/>
            </t>
        </t>
    </template>


</odoo>