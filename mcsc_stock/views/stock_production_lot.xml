<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="stock_production_lot_mcsc" model="ir.actions.act_window">
        <field name="name">METRC Production Lot</field>
        <field name="res_model">stock.lot</field>
        <field name="view_mode">list</field>
        <field name='help' type='html'>
            <p class="o_view_nocontent_smiling_face">Create the first lot</p>
        </field>
    </record>

    <record id="view_production_lot_tree" model="ir.ui.view">
        <field name="name">stock_production_lot.view.list</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="replace">
                <list string="METRC Inventory Audit">
                    <field name="name"/>
                    <field name="product_id"></field>
                    <field name="metrc_id"></field>
                    <field name="metrc_qty"></field>
                    <field name="metrc_unit_of_measure"></field>
                    <field name="product_qty"></field>
                    <field name="qty_difference"></field>
                    <field name="last_update_metrc"></field>
                </list>
            </xpath>
        </field>
    </record>
    <menuitem id="menu_item_stock_production_lot_mcsc" name="METRC Inventory Audit" sequence="0" parent="stock.menu_warehouse_report" action="stock_production_lot_mcsc"/>
</odoo>
