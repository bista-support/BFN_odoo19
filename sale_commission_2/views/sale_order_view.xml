<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_order_agent_form_inherit" model="ir.ui.view">
        <field name="name">sale.agent.order.inherit.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <xpath
                expr="//field[@name='order_line']/list//field[@name='price_subtotal']"
                position="after"
            >
                <field name="commission_free" invisible="1" />
                <field name="has_invoice_lines" invisible="1" />
                <button
                    name="button_edit_agents"
                    title="Edit agents"
                    icon="fa-users"
                    type="object"
                    invisible="commission_free == True or has_invoice_lines == True or is_service_product == True"
                    groups="commission.group_commission_manager"
                />

                <field name="commission_status" optional="show" groups="commission.group_commission_manager"/>
                <field name="is_service_product" invisible="1" />
            </xpath>
            <field name="tax_totals" position="after">
                <field
                    name="commission_total"
                    widget="monetary"
                    options="{'currency_field': 'currency_id'}"
                    invisible="1"
                />
            </field>
            <xpath expr="//field[@name='note']" position="after">
                <group name="group_recompute_commission">
                    <button
                        name="recompute_lines_agents"
                        type="object"
                        string="Regenerate agents"
                        invisible="state not in ['draft', 'sent']"
                        groups="commission.group_commission_manager"
                    />
                    <button
                        name="recompute_lines_agents_amount"
                        type="object"
                        string="Recompute amounts"
                        invisible="state not in ['draft', 'sent']"
                        groups="commission.group_commission_manager"
                    />
                </group>
            </xpath>

            <xpath expr="//field[@name='user_id']" position="after">
                <field name="sale_agent_id" readonly="1" domain="[('only_agent', '=', True)]"/>
                <field name="pm_agent_ids" invisible="1"/>
                <field name="pm_agent_id" readonly="1"/>
                <field name="commission_paid" readonly="1"/>
                <field name="commission_paid_date" readonly="1"/>

            </xpath>
        </field>
    </record>
    <record id="view_sales_order_filter_agent" model="ir.ui.view">
        <field name="name">view_sales_order_filter_agent</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_sales_order_filter" />
        <field name="arch" type="xml">
            <field name="user_id" position="after">
                <field name="partner_agent_ids" />
                
            </field>
        </field>
    </record>
    <!-- This view is needed for proper visualization of the popup / embedded one2many -->
    <record model="ir.ui.view" id="view_sale_order_line_tree">
        <field name="name">sale.order.line.agent.list</field>
        <field name="model">sale.order.line.agent</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field
                    name="agent_id"
                    context="{'default_agent': True, 'default_customer': False, 'default_supplier': True}"
                />
                <field
                    name="commission_id"
                    domain="['|', ('settlement_type', '=', 'sale_invoice'), ('settlement_type', '=', False)]"
                />
                <field name="amount" />
            </list>
        </field>
    </record>
    <record id="view_res_config_settings_inherit_sale" model="ir.ui.view">
        <field name="name">res.config.settings.inherit.sale</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <!-- Insert after an existing section or group -->
            <xpath expr='//block[@name="catalog_setting_container"]' position="after">
                <h2>Sales Manager Commission</h2>
                <div class="row mt16 o_settings_container">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane" />
                        <div class="o_setting_right_pane">
                            <label for="my_partner_id" />
                            <div class="text-muted">Select a default sales Manager for your commission.</div>
                            <field name="my_partner_id" domain="[('pm_agent', '=', True)]"/>
                        </div>
                    </div>
                </div>
            </xpath>

        </field>
    </record>

</odoo>
